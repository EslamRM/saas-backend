{
  "info": {
    "name": "SaaS Subscription Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register-tenant",
              "host": ["{{base_url}}"],
              "path": ["auth", "register-tenant"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Test Corp\",\n  \"adminEmail\": \"admin@test.com\",\n  \"adminPassword\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Acme Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('token', res.accessToken);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Plans",
      "item": [
        {
          "name": "Create Plan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/plans", "host": ["{{base_url}}"], "path": ["plans"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Platinum Plan\",\n  \"price\": 1000,\n  \"currency\": \"USD\",\n  \"intervalDays\": 30\n}"
            }
          }
        },
        {
          "name": "Get All Plans",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/plans", "host": ["{{base_url}}"], "path": ["plans"] }
          }
        },
        {
          "name": "Soft Delete Plan",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/plans/PLAN_ID_HERE", "host": ["{{base_url}}"], "path": ["plans", "PLAN_ID_HERE"] }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/customers", "host": ["{{base_url}}"], "path": ["customers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Charlie Brown\",\n  \"email\": \"charlie@example.com\"\n}"
            }
          }
        },
        {
          "name": "Get All Customers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/customers", "host": ["{{base_url}}"], "path": ["customers"] }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Create Subscription",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/subscriptions", "host": ["{{base_url}}"], "path": ["subscriptions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUSTOMER_ID_HERE\",\n  \"planId\": \"PLAN_ID_HERE\",\n  \"startDate\": \"2025-02-01\"\n}"
            }
          }
        },
        {
          "name": "Get All Subscriptions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/subscriptions", "host": ["{{base_url}}"], "path": ["subscriptions"] }
          }
        }
      ]
    },
    {
      "name": "Billing",
      "item": [
        {
          "name": "Generate Monthly Invoices",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/billing/generate-monthly-invoices", "host": ["{{base_url}}"], "path": ["billing", "generate-monthly-invoices"] }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Record Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/payments", "host": ["{{base_url}}"], "path": ["payments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceId\": \"INVOICE_ID_HERE\",\n  \"amount\": 100.00\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Accounting",
      "item": [
        {
          "name": "Recognize Revenue",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/accounting/recognize-revenue", "host": ["{{base_url}}"], "path": ["accounting", "recognize-revenue"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"month\": \"2025-01\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Balance Sheet",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/reports/balance-sheet", "host": ["{{base_url}}"], "path": ["reports", "balance-sheet"] }
          }
        },
        {
          "name": "Income Statement",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/reports/income-statement?from=2025-01-01&to=2025-01-31",
              "host": ["{{base_url}}"],
              "path": ["reports", "income-statement"],
              "query": [
                { "key": "from", "value": "2025-01-01" },
                { "key": "to", "value": "2025-01-31" }
              ]
            }
          }
        }
      ]
    }
  ]
}